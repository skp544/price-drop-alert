# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/price-drop-alert

# Email (Gmail SMTP)
# Use a Gmail App Password — NOT your regular Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM="Price Drop Alert <your-gmail@gmail.com>"

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Cron Schedule (default: every day at midnight)
# Examples: "0 0 * * *" = daily at midnight, "0 9 * * *" = daily at 9am, "0 * * * *" = every hour
CRON_SCHEDULE=0 0 * * *

# Scraper settings
SCRAPER_TIMEOUT=30000
SCRAPER_RETRY_ATTEMPTS=3
SCRAPER_DELAY_MS=2000
